generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id
  email              String             @unique
  nome               String
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  gcalConnected      Boolean            @default(false) @map("gcal_connected")
  gcalEmail          String?            @map("gcal_email")
  googleRefreshToken String?            @map("google_refresh_token")
  gcalLastSync       DateTime?          @map("gcal_last_sync")
  gcalTokenStatus      String               @default("disconnected") @map("gcal_token_status")
  gcalLastError        String?              @map("gcal_last_error")
  gcalSyncToken        String?              @map("gcal_sync_token")
  gcalChannelId        String?              @map("gcal_channel_id")
  gcalChannelExpiresAt DateTime?            @map("gcal_channel_expires_at")
  geminiApiKey         String?              @map("gemini_api_key")
  aulas              Aula[]
  bloqueiosAgenda    BloqueioAgenda[]
  cadernos           Caderno[]
  decks              Deck[]
  eventosAcademicos  EventoAcademico[]
  gradeFaculdade     GradeFaculdade[]
  materiaisEstudo    MaterialEstudo[]
  materias           Materia[]
  notificacoes       Notificacao[]
  ocorrenciasGrade   OcorrenciaGrade[]
  resumos            Resumo[]
  revisoes           Revisao[]
  sessoes            SessaoEstudo[]
  tentativas         TentativaQuestao[]
  preferences        UserPreferences?
  profile            UserProfile?

  @@map("users")
}

model UserProfile {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  bio          String?
  instituicao  String?
  curso        String?
  semestre     String?
  turno        String?
  fotoUrl      String?  @map("foto_url")
  rotina       String?
  plano        String?  @default("free")
  goalsJson    Json     @default("[]") @map("goals_json")
  settingsJson Json     @default("{}") @map("settings_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserPreferences {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  preferencesJson Json     @map("preferences_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Materia {
  id                     String            @id @default(uuid())
  userId                 String            @map("user_id")
  nome                   String
  cor                    String
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  descricao              String?
  exibirNoCalendario     Boolean           @default(true) @map("exibir_no_calendario")
  iaHabilitada           Boolean           @default(false) @map("ia_habilitada")
  limiteFaltasPercentual Float?            @map("limite_faltas_percentual")
  metaSemanalHoras       Float?            @map("meta_semanal_horas")
  numeroPeriodo          Int?              @map("numero_periodo")
  periodoFim             DateTime?         @map("periodo_fim")
  periodoInicio          DateTime?         @map("periodo_inicio")
  pesoImportancia        String?           @map("peso_importancia")
  prioridade             String?
  professor              String?
  revisaoAutomaticaAtiva Boolean           @default(true) @map("revisao_automatica_ativa")
  status                 String            @default("em_andamento")
  tipoPeriodo            String?           @map("tipo_periodo")
  aulas                  Aula[]
  eventos                EventoAcademico[]
  faltas                 FaltaMateria[]
  gradeFaculdade         GradeFaculdade[]
  materiais              MaterialEstudo[]
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notas                  NotaMateria[]
  ocorrenciasGrade       OcorrenciaGrade[]
  resumos                Resumo[]
  revisoes               Revisao[]
  sessoesEstudo          SessaoEstudo[]
  topicos                Topico[]

  @@map("materias")
}

model NotaMateria {
  id         String   @id @default(uuid())
  materiaId  String   @map("materia_id")
  nome       String
  notaMaxima Float    @map("nota_maxima")
  notaObtida Float?   @map("nota_obtida")
  createdAt  DateTime @default(now()) @map("created_at")
  materia    Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@map("notas_materia")
}

model Topico {
  id            String         @id @default(uuid())
  materiaId     String         @map("materia_id")
  nome          String
  statusDominio String         @default("iniciante") @map("status_dominio")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  aulas         Aula[]
  resumos       Resumo[]
  revisoes      Revisao[]
  sessoesEstudo SessaoEstudo[]
  materia       Materia        @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@map("topicos")
}

model SessaoEstudo {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  materiaId             String?  @map("materia_id")
  topicoId              String?  @map("topico_id")
  tipo                  String   @default("pomodoro")
  tempoEstudadoSegundos Int      @map("tempo_estudado_segundos")
  createdAt             DateTime @default(now()) @map("created_at")
  acertos               Int?
  dificuldade           Int?
  notas                 String?
  origemSessao          String?  @map("origem_sessao")
  professor             String?
  titulo                String?
  totalQuestoes         Int?     @map("total_questoes")
  materia               Materia? @relation(fields: [materiaId], references: [id])
  topico                Topico?  @relation(fields: [topicoId], references: [id])
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessoes_estudo")
}

model Revisao {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  materiaId    String            @map("materia_id")
  topicoId     String?           @map("topico_id")
  nome         String
  status       String            @default("pendente")
  dataPrevista DateTime          @map("data_prevista")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  aulaId       String?           @map("aula_id")
  eventos      EventoAcademico[]
  materia      Materia           @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  topico       Topico?           @relation(fields: [topicoId], references: [id])
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("revisoes")
}

model Resumo {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  materiaId String?  @map("materia_id")
  topicoId  String?  @map("topico_id")
  titulo    String
  conteudo  String
  origem    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  materia   Materia? @relation(fields: [materiaId], references: [id])
  topico    Topico?  @relation(fields: [topicoId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumos")
}

model Deck {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  nome       String
  origem     String      @default("manual")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  aulaId     String?     @map("aula_id")
  descricao  String?
  materiaId  String?     @map("materia_id")
  topicoId   String?     @map("topico_id")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]

  @@map("decks")
}

model Flashcard {
  id              String    @id @default(uuid())
  deckId          String    @map("deck_id")
  frente          String
  verso           String
  intervalo       Int       @default(0)
  repeticoes      Int       @default(0)
  fatorFacilidade Float     @default(2.5) @map("fator_facilidade")
  proximaRevisao  DateTime? @map("proxima_revisao")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deck            Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

model Caderno {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  nome          String
  descricao     String?
  questoesCount Int       @default(0) @map("questoes_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questoes      Questao[]

  @@map("cadernos")
}

model Questao {
  id           String               @id @default(uuid())
  cadernoId    String               @map("caderno_id")
  enunciado    String
  tipo         String               @default("multipla_escolha")
  dificuldade  String               @default("media")
  origem       String               @default("manual")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  alternativas AlternativaQuestao[]
  caderno      Caderno              @relation(fields: [cadernoId], references: [id], onDelete: Cascade)
  tentativas   TentativaQuestao[]

  @@map("questoes")
}

model AlternativaQuestao {
  id        String  @id @default(uuid())
  questaoId String  @map("questao_id")
  texto     String
  correta   Boolean @default(false)
  questao   Questao @relation(fields: [questaoId], references: [id], onDelete: Cascade)

  @@map("alternativas_questao")
}

model TentativaQuestao {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  questaoId String   @map("questao_id")
  acertou   Boolean
  createdAt DateTime @default(now()) @map("created_at")
  questao   Questao  @relation(fields: [questaoId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tentativas_questao")
}

model EventoAcademico {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  materiaId        String?   @map("materia_id")
  revisaoId        String?   @map("revisao_id")
  titulo           String
  descricao        String?
  tipo             String    @default("evento")
  origem           String    @default("sistema")
  dataInicio       DateTime  @map("data_inicio")
  dataFim          DateTime  @map("data_fim")
  diaInteiro       Boolean   @default(false) @map("dia_inteiro")
  local            String?
  cor              String?
  concluido        Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  googleEventId    String?   @map("google_event_id")
  googleCalendarId String?   @map("google_calendar_id")
  htmlLink         String?   @map("html_link")
  googleStatus     String?   @map("google_status")
  syncStatus       String    @default("pendente") @map("sync_status")
  lastSyncAt       DateTime? @map("last_sync_at")
  aulaId           String?   @map("aula_id")
  materia          Materia?  @relation(fields: [materiaId], references: [id])
  revisao          Revisao?  @relation(fields: [revisaoId], references: [id])
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("eventos_academicos")
}

model Aula {
  id                    String           @id @default(uuid())
  materiaId             String           @map("materia_id")
  titulo                String
  status                String           @default("agendada")
  data                  DateTime?
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")
  metadataJson          Json?            @map("metadata_json")
  observacoes           String?
  professor             String?
  reposicaoOcorrenciaId String?          @map("reposicao_ocorrencia_id")
  topicoId              String?          @map("topico_id")
  userId                String           @map("user_id")
  materia               Materia          @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  topico                Topico?          @relation(fields: [topicoId], references: [id])
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  materiais             MaterialEstudo[]

  @@map("aulas")
}

model MaterialEstudo {
  id                String   @id @default(uuid())
  materiaId         String   @map("materia_id")
  aulaId            String?  @map("aula_id")
  titulo            String
  tipo              String   @default("link")
  url               String?
  googleDriveFileId String?  @map("google_drive_file_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  conteudo          String?
  metadataJson      Json?    @map("metadata_json")
  topicoId          String?  @map("topico_id")
  userId            String   @map("user_id")
  aula              Aula?    @relation(fields: [aulaId], references: [id])
  materia           Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("materiais_estudo")
}

model Notificacao {
  id           String   @id @default(uuid())
  tipo         String
  titulo       String
  mensagem     String
  lida         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  metadataJson Json?    @map("metadata_json")
  status       String   @default("active")
  updatedAt    DateTime @updatedAt @map("updated_at")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificacoes")
}

model GradeFaculdade {
  id                     String    @id @default(uuid())
  userId                 String    @map("user_id")
  titulo                 String
  diasSemana             Int[]     @map("dias_semana")
  horaInicio             String    @map("hora_inicio")
  horaFim                String    @map("hora_fim")
  ativo                  Boolean   @default(true)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  cor                    String?
  dataEspecifica         DateTime? @map("data_especifica")
  dataFimVigencia        DateTime? @map("data_fim_vigencia")
  dataInicioVigencia     DateTime? @map("data_inicio_vigencia")
  limiteFaltasPercentual Float?    @map("limite_faltas_percentual")
  local                  String?
  materiaId              String?   @map("materia_id")
  numeroPeriodo          Int?      @map("numero_periodo")
  observacoes            String?
  periodoFim             DateTime? @map("periodo_fim")
  periodoInicio          DateTime? @map("periodo_inicio")
  professor              String?
  recorrente             Boolean   @default(true)
  tipoPeriodo            String?   @map("tipo_periodo")
  materia                Materia?  @relation(fields: [materiaId], references: [id])
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("grade_faculdade")
}

model BloqueioAgenda {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  titulo             String
  categoria          String    @default("pessoal")
  horaInicio         String    @map("hora_inicio")
  horaFim            String    @map("hora_fim")
  recorrente         Boolean   @default(true)
  diasSemana         Int[]     @map("dias_semana")
  ativo              Boolean   @default(true)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  cor                String?
  dataEspecifica     DateTime? @map("data_especifica")
  dataFimVigencia    DateTime? @map("data_fim_vigencia")
  dataInicioVigencia DateTime? @map("data_inicio_vigencia")
  observacoes        String?
  tipo               String    @default("bloqueio")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bloqueios_agenda")
}

model FaltaMateria {
  id        String   @id @default(uuid())
  materiaId String   @map("materia_id")
  data      DateTime
  createdAt DateTime @default(now()) @map("created_at")
  materia   Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@map("faltas_materias")
}

model OcorrenciaGrade {
  id                    String   @id @default(uuid())
  materiaId             String   @map("materia_id")
  data                  DateTime
  status                String   @default("pendente_confirmacao")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  aulaId                String?  @map("aula_id")
  gradeId               String?  @map("grade_id")
  observacoes           String?
  origem                String?
  quantidadeOcorrencias Int      @default(1) @map("quantidade_ocorrencias")
  reposicaoAulaId       String?  @map("reposicao_aula_id")
  reposicaoObservacao   String?  @map("reposicao_observacao")
  reposicaoSessaoId     String?  @map("reposicao_sessao_id")
  statusReposicao       String?  @default("pendente") @map("status_reposicao")
  tipoFalta             String?  @map("tipo_falta")
  topicoId              String?  @map("topico_id")
  userId                String   @map("user_id")
  materia               Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ocorrencias_grade")
}
